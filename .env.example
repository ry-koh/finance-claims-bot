# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token

# ─── Google (Drive, Docs, Sheets, Gmail) ─────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GOOGLE_DRIVE_PARENT_FOLDER_ID=your-drive-folder-id
DRIVE_REFRESH_TOKEN=your-drive-refresh-token

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=finance-claims

# ─── URLs ────────────────────────────────────────────────────────────────────
APP_URL=https://your-backend.a.run.app
MINI_APP_URL=https://your-app.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app

# ─── Notes ───────────────────────────────────────────────────────────────────
# FD details (name, matric, phone, email) and academic year are configured
# in-app by the Finance Director via the Settings page — not set here.
#
# See SETUP.md for instructions on generating the OAuth refresh tokens.
