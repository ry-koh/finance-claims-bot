# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400
TELEGRAM_WEBHOOK_SECRET_TOKEN=
REGISTER_TELEGRAM_WEBHOOK_ON_STARTUP=false

# Google APIs (service account for Drive/Docs/Sheets)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Gmail OAuth (for sending emails)
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# Google Drive
GOOGLE_DRIVE_PARENT_FOLDER_ID=your-drive-folder-id

# App config
ACADEMIC_YEAR=2526
ALLOWED_ORIGINS=https://your-app.vercel.app
DOCGEN_MAX_WORKERS=1
MAX_UPLOAD_BYTES=8000000
MAX_PDF_PAGES=20

# Public HTTPS URL of this backend — used for Telegram webhook registration
APP_URL=https://your-domain.duckdns.org

# Vercel frontend URL — used by the bot for the Mini App button
MINI_APP_URL=https://your-app.vercel.app
